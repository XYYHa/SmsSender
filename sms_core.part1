            'EM-MD': "ODViZTY1ZTYxYzY4OThlNTM3MjdjZWI1MzFmMDFkNGJ8fGmMbWlfdGx1YWZlZF9tZQ%3D%3D",
            'EM-CHL': "nearme26_64",
            'EM-GV': "1cae15346",
            'EM-CT': "",
            'EM-UT': "",
            'EM-SL': "0",
            'EM-PA': "1",
            'em-dns': "1"
        }
        
        # 发送请求
        response = requests.post(
            url=url,
