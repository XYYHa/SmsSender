        RSA_PLAIN_TEMPLATE = f"phone={phone}&type=register&encript_key=RQACYEZPWMANBOLNXFZPUCMC&"
        # MD5签名配置
        SIGN_PARAMS = {
            "user_agent": "sojex/3.9.7(Anroid;15;2958*2120);UA198",
            "rtp": "sms/sendPhoneCode",
            "time": CURRENT_TIMESTAMP,
            "app_name": "gkoudai",
